# Copy to .env and fill in. All keys are optional for basic feed collection.
# Docker Compose: same file is used for variable substitution (see docker-compose.yml).
# Docker Compose: host port mapped to container 8000 (default host port 8767).
# APP_PORT=9000

# Feed 内存缓存 TTL（秒）。过期后普通 GET /api/feed 会重新抓取；默认 1800（30 分钟）。
# FEED_CACHE_TTL_SECONDS=1800

# Database (default: sqlite:///./data/ai_news.db)
# DATABASE_URL=sqlite:///./data/ai_news.db
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/ai_news

# --- LLM: weekly digest & /api/summarize (configure at least one provider) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# MODELVERSE_API_KEY=
# MODELVERSE_MODEL=qwen-turbo

# --- 内容增强: /api/enhance, /api/scrape ---
# ENHANCE_PROVIDER=auto | crawl4ai | firecrawl
# - auto（默认）：有 FIRECRAWL_API_KEY 走 Firecrawl；否则走 Crawl4AI
# - crawl4ai：本地免费抓取（需要 playwright 浏览器）
# - firecrawl：强制 Firecrawl（需要额度与 FIRECRAWL_API_KEY）
# ENHANCE_PROVIDER=auto
#
# Crawl4AI 需要额外安装浏览器（本地环境）：
#   pip install -r requirements.txt
#   python -m playwright install chromium
#
# Crawl4AI 可选调参（抓取质量与性能）：
# - CRAWL4AI_USER_AGENT：自定义 UA（减少被站点屏蔽）
# - CRAWL4AI_ACCEPT_LANGUAGE：Accept-Language 头（默认 en+zh）
# - CRAWL4AI_PAGE_TIMEOUT：页面超时毫秒（默认 55000）
# - CRAWL4AI_DELAY_HTML：返回前等待渲染的秒数基线（默认 0.65；GitHub 等会叠加额外延迟）
# - CRAWL4AI_BYPASS_CACHE：是否绕过 Crawl4AI 内部缓存（默认 true）
# - CRAWL4AI_PROCESS_IFRAMES：是否处理 iframe（默认关；部分嵌入页可开）
# - CRAWL4AI_HEADLESS：无头浏览器（默认 true）
# - CRAWL4AI_USE_SMART_WAIT：对支持的域名使用 wait_for 再抽主内容（默认关）
# - CRAWL4AI_SIMULATE_USER：质量分仍低时重试并 simulate_user（滚动等，较慢；默认关）
# - CRAWL4AI_SIMULATE_MIN_SCORE：低于该质量分才触发 simulate（默认 220）
# - CRAWL4AI_CSS_SELECTORS：逗号分隔，覆盖内置域名启发；优先尝试前 5 个选择器
# CRAWL4AI_USER_AGENT=
# CRAWL4AI_ACCEPT_LANGUAGE=en-US,en;q=0.9,zh-CN;q=0.8,zh;q=0.7
# CRAWL4AI_PAGE_TIMEOUT=55000
# CRAWL4AI_DELAY_HTML=0.65
# CRAWL4AI_BYPASS_CACHE=true
# CRAWL4AI_PROCESS_IFRAMES=false
# CRAWL4AI_HEADLESS=true
# CRAWL4AI_USE_SMART_WAIT=false
# CRAWL4AI_SIMULATE_USER=false
# CRAWL4AI_SIMULATE_MIN_SCORE=220
# CRAWL4AI_CSS_SELECTORS=main article,article,main,#content,.post-content,.article-content,.content,body
#
# Firecrawl（可选，若你仍想用托管抓取）：
# FIRECRAWL_API_KEY=

# --- /api/analytics/industry (AI Agent 工程行业影响分布) ---
# 无需额外 Key 即可使用规则打分模式。
# 若要启用 LLM 增强打分（?use_llm=true），需配置上方至少一个 LLM Key。
# force_rescore=true 可清除旧缓存并重新评分；默认增量（跳过已打分条目）。
