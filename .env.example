# Copy to .env and fill in. All keys are optional for basic feed collection.
# Docker Compose: same file is used for variable substitution (see docker-compose.yml).
# Docker Compose: host port mapped to container 8000 (default host port 8767).
# APP_PORT=9000

# Feed 内存缓存 TTL（秒）。过期后普通 GET /api/feed 会重新抓取；默认 1800（30 分钟）。
# FEED_CACHE_TTL_SECONDS=1800

# Database (default: sqlite:///./data/ai_news.db)
# DATABASE_URL=sqlite:///./data/ai_news.db
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/ai_news

# --- LLM: weekly digest & /api/summarize (configure at least one provider) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# MODELVERSE_API_KEY=
# MODELVERSE_MODEL=qwen-turbo

# --- 内容增强: /api/enhance, /api/scrape ---
# ENHANCE_PROVIDER=auto | crawl4ai | firecrawl
# - auto（默认）：有 FIRECRAWL_API_KEY 走 Firecrawl；否则走 Crawl4AI
# - crawl4ai：本地免费抓取（需要 playwright 浏览器）
# - firecrawl：强制 Firecrawl（需要额度与 FIRECRAWL_API_KEY）
# ENHANCE_PROVIDER=auto
#
# Crawl4AI 需要额外安装浏览器（本地环境）：
#   pip install -r requirements.txt
#   python -m playwright install chromium
#
# Firecrawl（可选，若你仍想用托管抓取）：
# FIRECRAWL_API_KEY=

# --- /api/analytics/industry (AI Agent 工程行业影响分布) ---
# 无需额外 Key 即可使用规则打分模式。
# 若要启用 LLM 增强打分（?use_llm=true），需配置上方至少一个 LLM Key。
# force_rescore=true 可清除旧缓存并重新评分；默认增量（跳过已打分条目）。
